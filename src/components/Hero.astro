---
import { t } from "astro-i18n";

import photo_wedding_couple_900_1200 from "@assets/photo_wedding_couple_900_1200.jpeg?url";
---

<div class="hero min-h-svh">
  <div class="hero-content flex-col-reverse gap-4 lg:flex-row-reverse">
    <img
      src={photo_wedding_couple_900_1200}
      alt="Couple Photo"
      class="h-auto w-auto max-w-full rounded-lg shadow-xl md:max-w-sm xl:max-w-md 2xl:max-w-lg"
    />
    <div class="min-w-0 text-center lg:text-left">
      <h1 class="py-6 font-serif text-5xl lg:py-12 xl:text-6xl 2xl:text-7xl">{t("hero.headline1")}</h1>
    </div>
  </div>
</div>
